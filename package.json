{
  "name": "final-lead-finder",
  "version": "1.0.0",
  "description": "KI-gestützter Lead-Generator für Webdesign",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:win": "pkg server.js --target node18-win-x64 --output dist/LeadFinder.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/puppeteer-core/**/*"
    ],
    "scripts": [
      "src/**/*.js",
      "server.js"
    ]
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "express": "^4.18.2",
    "openai": "^4.24.0",
    "puppeteer": "^22.0.0",
    "puppeteer-core": "^22.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1"
  }
}
