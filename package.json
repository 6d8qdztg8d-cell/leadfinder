{
  "name": "lead-finder",
  "version": "2.2.0",
  "description": "KI-gestützter Lead-Generator für Webdesign",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --arm64"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "openai": "^4.24.0",
    "puppeteer-core": "^22.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.0.2"
  },
  "build": {
    "appId": "com.leadfinder.app",
    "productName": "LeadFinder",
    "files": [
      "main.js",
      "server.js",
      "src/**/*",
      "package.json",
      "node_modules/**/*",
      "!data/**",
      "!public/**",
      "!**/.git/**",
      "!**/*.md"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": ["**/*", "!screenshots/**"]
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "LeadFinder-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64"] }],
      "artifactName": "LeadFinder-${version}-mac.dmg",
      "identity": null
    },
    "dmg": {
      "title": "LeadFinder Installer"
    }
  }
}
