{
  "name": "lead-finder",
  "version": "1.0.0",
  "description": "KI-gestützter Lead-Generator für Webdesign",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "node server.js",
    "build": "electron-builder --win --publish=never"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "express": "^4.18.2",
    "openai": "^4.24.0",
    "puppeteer-core": "^22.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "nodemon": "^3.0.2",
    "puppeteer": "^22.0.0"
  },
  "build": {
    "appId": "com.leadfinder.app",
    "productName": "LeadFinder",
    "copyright": "LeadFinder",
    "win": {
      "target": "nsis",
      "artifactName": "LeadFinder-Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LeadFinder"
    },
    "files": [
      "main.js",
      "server.js",
      "src/**",
      "node_modules/**",
      "!node_modules/puppeteer/**",
      "!node_modules/.cache/**"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public",
        "filter": ["**/*", "!screenshots/**"]
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
