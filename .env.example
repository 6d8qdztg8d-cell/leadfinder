# LeadFinder — Umgebungsvariablen
# Kopiere diese Datei als ".env" und passe die Werte an.

# Port des Webservers (Standard: 3737)
PORT=3737

# Passwortschutz — wenn gesetzt, fragt der Browser nach einem Passwort.
# Benutzername kann beliebig sein, nur das Passwort zählt.
# Leer lassen = kein Passwortschutz (nur im lokalen Netz empfohlen).
ADMIN_PASSWORD=deinPasswort

# Datenpfad (Standard: ./data)
# DATA_DIR=/pfad/zu/daten

# Screenshot-Pfad (Standard: ./public/screenshots)
# SCREENSHOTS_DIR=/pfad/zu/screenshots
